{
  "mcpServers": {
    "movp": {
      "type": "stdio",
      "command": "node",
      "args": ["/absolute/path/to/movp-mcp/dist/index.js"],
      "env": {
        "WORKDESK_SERVICE_URL": "http://localhost:8115",
        "WORKDESK_TENANT": "your-tenant-id",
        "WORKDESK_API_KEY": "your-api-key"
      }
    }
  }
}
